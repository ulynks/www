{
  "author": "@JV-conseil",
  "browserslist": "> 1%",
  "bugs": {
    "url": "https://github.com/ulynks/www/issues"
  },
  "dependencies": {
    "@fontsource/poppins": "^5.2.7",
    "@popperjs/core": "^2.11.8",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "coi-serviceworker": "^0.1.7",
    "dompurify": "^3.4.11",
    "jquery": "^4.0.0"
  },
  "description": "Growing on Fyn, Denmark 🇩🇰",
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/preset-env": "^8.0.2",
    "autoprefixer": "^10.5.2",
    "babel-loader": "^10.1.1",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "braces": "^3.0.3",
    "core-js": "^3.49.0",
    "css-loader": "^7.1.4",
    "css-minimizer-webpack-plugin": "^8.0.0",
    "depcheck": "^1.4.7",
    "mini-css-extract-plugin": "^2.10.2",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.16",
    "postcss-loader": "^8.2.1",
    "sass": "^1.101.0",
    "webpack": "^5.108.3",
    "webpack-cli": "^7.1.0"
  },
  "homepage": "https://github.com/ulynks/www#readme",
  "keywords": [],
  "license": "EUPL-1.2",
  "main": "index.js",
  "name": "uLynks",
  "packageManager": "yarn@4.17.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ulynks/www.git"
  },
  "scripts": {
    "assets": "(yarn run sass & yarn run vendor) && yarn run start:webpack",
    "build": "run-s build:webpack build:hugo",
    "build:hugo": "hugo",
    "build:webpack": "webpack --mode=production",
    "dev:webpack": "webpack --mode=development --watch",
    "sass-v1": "sass --load-path=node_modules/ --no-source-map themes/ulynks/assets/scss/app.scss themes/ulynks/assets/css/app.css --style=compressed",
    "sass": "sass --no-source-map --load-path=node_modules --style=compressed --verbose --quiet-deps --silence-deprecation=import --silence-deprecation=global-builtin themes/ulynks/assets/scss/app.scss themes/ulynks/assets/css/app.css",
    "start": "run-p 'start:*'",
    "start:hugo": "hugo version && hugo server --config=hugo-dev --buildDrafts --logLevel=debug --ignoreCache=true --gc --minify",
    "start:webpack": "webpack --mode=production",
    "start:firefox": "open -na /Applications/Firefox.app --args '--private-window' 'http://localhost:1313/'",
    "test": "echo \"Error: no test specified\" && exit 1",
    "vendor": ".bash/vendor.sh",
    "yarn-update": "yarn set version stable && yarn install && yarn up && yarn npm audit && ( npx depcheck --detailed ) || : && yarn upgrade-interactive"
  }
}